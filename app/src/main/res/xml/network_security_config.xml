<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug overrides: trust user certificates for proxy/WireMock debugging -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
    
    <!-- Localhost configuration for WireMock and local development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
